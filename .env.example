# Production deployment (docker compose up --build -d):
# - Single docker-compose.yml runs api, web, nginx.
# - nginx exposes port 8080; point external reverse proxy
#   (Nginx Proxy Manager) to this port for HTTPS termination.
# - bind-mount ./src and ./app_data on api for fast updates via git pull.
# - VITE_API_BASE="" (relative paths through nginx, set in compose).

ADMIN_USERNAME=
ADMIN_PASSWORD=
SECRET_KEY=
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
DB_PATH=app_data/telesoft.db
# 4 built-in link patterns are seeded into link_patterns on first init
# (is_builtin=1, cannot be deleted). See issue #59.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
# StringSession auth string — prevents FloodWait on restart by reusing auth.
# Generate: python -c "from telethon.sessions import StringSession; print(StringSession.save('app_data/bot.session'))"
TELEGRAM_SESSION_STRING=
SESSION_PATH=app_data/bot.session
JOBS_MAX_CONCURRENCY=3
TELEGRAM_REQUEST_DELAY=1.0
TELEGRAM_EDIT_DELAY=5.0